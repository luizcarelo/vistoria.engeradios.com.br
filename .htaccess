# Configurações de segurança e otimização

# Habilitar rewrite engine
RewriteEngine On

# Bloquear acesso a arquivos sensíveis
<FilesMatch "(^#.*#|\.(bak|config|sql|fla|psd|ini|log|sh|inc|swp|dist)|~)$">
    Order allow,deny
    Deny from all
    Satisfy All
</FilesMatch>

# --- CORREÇÃO ---
# A regra de hotlinking estava bloqueando o seu próprio logo.
# 1. Corrigido para permitir o subdomínio 'vistoria.engeradios.com.br'.
# 2. Corrigido para proteger APENAS imagens DENTRO da pasta /uploads/.

# Proteção contra hotlinking de imagens (CORRIGIDO)
RewriteCond %{HTTP_REFERER} !^$
RewriteCond %{HTTP_REFERER} !^http(s)?://(www\.)?vistoria\.engeradios\.com\.br [NC]
RewriteCond %{REQUEST_URI} ^/uploads/ [NC]  # <-- Corrigido: protege apenas /uploads/
RewriteRule \.(jpg|jpeg|png|gif|webp)$ - [NC,F,L]

# Configurações de upload foram movidas para .user.ini
# Usar 'php_value' aqui pode causar Erro 500 em muitos servidores modernos (FastCGI/FPM)
# php_value upload_max_filesize 10M
# php_value post_max_size 10M
# php_value max_execution_time 300
# php_value max_input_time 300

# Habilitar compressão
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript
</IfModule>

# Cache de arquivos estáticos
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
</IfModule>

# Desabilitar listagem de diretórios
Options -Indexes

# Página de erro personalizada (opcional)
# ErrorDocument 404 /404.php
# ErrorDocument 500 /500.php

# php -- BEGIN cPanel-generated handler, do not edit
# Set the “ea-php83” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php83 .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit
